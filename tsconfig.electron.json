{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/electron",
    "rootDir": "electron",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["electron/tests/**", "electron/preload.ts"]
}
