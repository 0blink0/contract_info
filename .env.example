# --- Docker 一键部署（复制为 .env 后 docker compose up -d --build）---
POSTGRES_PASSWORD=change_me_strong_password
HTTP_PORT=8080

# --- 轩辕镜像 docker.xuanyuan.run（login 后取消下面 4 行注释，不要用 daemon 加速 + 短镜像名）---
# POSTGRES_IMAGE=docker.xuanyuan.run/library/postgres:16
# PYTHON_IMAGE=docker.xuanyuan.run/library/python:3.11-slim-bookworm
# NODE_IMAGE=docker.xuanyuan.run/library/node:20-alpine
# NGINX_IMAGE=docker.xuanyuan.run/library/nginx:1.27-alpine

# 容器内 API 连接（compose 会覆盖 DATABASE_URL，此处供参考）
DATABASE_URL=postgresql+psycopg2://postgres:change_me_strong_password@postgres:5432/contract_info

# 生产建议设置；前端构建时写入 VITE_API_KEY（与 API_KEY 相同）
API_KEY=

# 经 nginx 同源访问时 CORS 可不配；若直连 API 端口再填写
CORS_ORIGINS=

# --- LLM（抽取阶段可选）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=120
LLM_MAX_RETRIES=1

# --- 本地 venv 开发（仅 postgres 容器，端口 5433）---
# DATABASE_URL=postgresql+psycopg2://postgres:contract_info_dev@localhost:5433/contract_info
